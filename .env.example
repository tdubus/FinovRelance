# =============================================================
#  FinovRelance - Variables d'environnement
#  Copier ce fichier en .env et remplir les valeurs
# =============================================================

# === Base de donnees ===
DATABASE_URL=postgresql://user:password@host:5432/finovrelance
# En dev local avec docker-compose :
# DATABASE_URL=postgresql://finovrelance:localdevpassword@db:5432/finovrelance
# En dev local sans Docker :
# DATABASE_URL=postgresql://finovrelance:localdevpassword@localhost:5432/finovrelance

# === Session Flask ===
SESSION_SECRET=GENERER_UNE_CLE_RANDOM_64_CHARS
FLASK_ENV=production
# En dev local : FLASK_ENV=development

# === OAuth Microsoft ===
MICROSOFT_CLIENT_ID=votre-client-id
MICROSOFT_CLIENT_SECRET=votre-client-secret
MICROSOFT_REDIRECT_URI=https://app.finov-relance.com/profile/microsoft/callback
# En dev local : MICROSOFT_REDIRECT_URI=http://localhost:5000/auth/microsoft/callback
MICROSOFT_TENANT=votre-tenant-id

# === Stripe ===
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
# En dev local, utiliser les cles sk_test_ et pk_test_

# === Business Central ===
BUSINESS_CENTRAL_CLIENT_ID=votre-client-id
BUSINESS_CENTRAL_CLIENT_SECRET=votre-client-secret

# === Xero ===
XERO_CLIENT_ID=votre-client-id
XERO_CLIENT_SECRET=votre-client-secret

# === QuickBooks (optionnel) ===
QUICKBOOKS_CLIENT_ID=votre-client-id
QUICKBOOKS_CLIENT_SECRET=votre-client-secret
QUICKBOOKS_SANDBOX=false

# === Chiffrement ===
ENCRYPTION_MASTER_KEY=GENERER_UNE_CLE_AES256_BASE64

# === Cron ===
# CRON_SECRET est utilise pour authentifier les appels aux cron jobs (header X-Job-Token)
CRON_SECRET=GENERER_UN_TOKEN_RANDOM

# === App config (routage par domaine) ===
APP_URL=https://app.finov-relance.com
MARKETING_URL=https://finov-relance.com
# En dev local, ne pas definir ces variables (tout est accessible sur localhost)
# En staging : APP_URL=https://test.finov-relance.com (pas de MARKETING_URL)

# === Mode developpeur ===
DEV_MODE=false
# En dev local : DEV_MODE=true
